{
    "name": "meniloss/symfony-skeleton-shbyjm",
    "type": "project",
    "license": "proprietary",
    "description": "Skeleton SHbyJM — base Symfony minimaliste pour tout nouveau site client, avec endpoint Flex SHbyJM pre-configure",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": ">=8.2",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "symfony/flex": "^2"
    },
    "flex-require": {
        "doctrine/doctrine-bundle": "*",
        "doctrine/doctrine-migrations-bundle": "*",
        "doctrine/orm": "*",
        "symfony/apache-pack": "*",
        "symfony/clock": "*",
        "symfony/console": "*",
        "symfony/dotenv": "*",
        "symfony/form": "*",
        "symfony/framework-bundle": "*",
        "symfony/mailer": "*",
        "symfony/messenger": "*",
        "symfony/runtime": "*",
        "symfony/translation": "*",
        "symfony/uid": "*",
        "symfony/yaml": "*"
    },
    "require-dev": {
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "bump-after-update": true,
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*"
    },
    "scripts": {
        "auto-scripts": [
        ],
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "repositories": [
        { "type": "vcs", "url": "https://github.com/meniloss/admin-shell" },
        { "type": "vcs", "url": "https://github.com/meniloss/lead-forwarding" },
        { "type": "vcs", "url": "https://github.com/meniloss/lead-management" }
    ],
    "extra": {
        "symfony": {
            "allow-contrib": true,
            "require": "7.4.*",
            "endpoint": [
                "https://api.github.com/repos/meniloss/recipes/contents/index.json",
                "flex://defaults"
            ]
        }
    }
}
